{
  "outputDirectory": "public",
  "cleanUrls": true,
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/auth", "destination": "/api/auth" },
    { "source": "/api/upload", "destination": "/api/upload" },
    { "source": "/api/metals", "destination": "/api/metals" },
    { "source": "/api/sessions", "destination": "/api/sessions" },
    { "source": "/api/psr", "destination": "/api/psr" },
    { "source": "/api/psr-auth", "destination": "/api/psr-auth" },
    { "source": "/psr/:slug", "destination": "/psr" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Resource-Policy", "value": "same-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' cdn.jsdelivr.net cdnjs.cloudflare.com cdn.sheetjs.com 'unsafe-inline'; style-src 'self' fonts.googleapis.com 'unsafe-inline'; font-src fonts.gstatic.com; img-src 'self' data: blob: https://analytics.miningforum.com; connect-src 'self' https://ljyogcspkvqgjbiyzfbn.supabase.co https://inhmwnaqgfjatrvfkkcu.supabase.co; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=3600" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=3600" }
      ]
    },
    {
      "source": "/logos/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/((?!api|css|js|logos).*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=60" }
      ]
    }
  ]
}
